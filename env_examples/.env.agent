# OmniMemEval Agent Memory Evaluation environment variables.
# Copy to .env.agent and fill in your values. Do not commit .env.agent.
#
# Usage:
#   cp env_examples/.env.agent .env.agent
#   ./scripts/run_agent_eval.sh --agent openclaw --domain reasoning --protocol test_only

# OpenClaw AgentBench model provider.
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-xxx

# DashScope-compatible aliases are also accepted.
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_API_KEY=sk-xxx

# LLM judge settings for domains that use verify_mode: llm.
JUDGE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
JUDGE_API_KEY=sk-xxx
JUDGE_MODEL=qwen3.6-flash

# Generic evaluation settings used by knowledge_work/GDPVal.
EVALUATION_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EVALUATION_API_KEY=sk-xxx
EVALUATION_MODEL_OWNER=openai
EVALUATION_MODEL_NAME=qwen3.6-flash
EVALUATION_TIMEOUT=240
EVALUATION_MAX_RETRIES=3

# BrowseComp-Plus embedding endpoint for dense retrieval.
IR_EMBEDDING_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1
IR_EMBEDDING_API_KEY=sk-xxx
IR_EMBEDDING_MODEL=text-embedding-v4
